{
  "family": "nodebase-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::539357031892:role/nodebase-exec-role",
  "taskRoleArn": "arn:aws:iam::539357031892:role/nodebase-task-role",
  "containerDefinitions": [
    {
      "name": "nodebase-container",
      "image": "539357031892.dkr.ecr.us-east-1.amazonaws.com/nodebase-app-repo:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "PORT",            "value": "3000" },
        { "name": "HOSTNAME",        "value": "0.0.0.0" },
        { "name": "AUTH_TRUST_HOST", "value": "true" },
        { "name": "NODE_ENV",        "value": "production" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/nodebase-app",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
